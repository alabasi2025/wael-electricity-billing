# =============================================
# Environment Variables
# النظام المحاسبي المتخصص لتجار الطاقة الكهربائية
# =============================================

# Server
PORT=3000
NODE_ENV=development

# Database
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_DATABASE=electricity_accounting

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=http://localhost:4200

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Pagination
DEFAULT_PAGE_SIZE=25
MAX_PAGE_SIZE=100

# ─── SMS Gateway ───
# الخيارات: twilio / nexmo / local_gateway / mock
SMS_PROVIDER=mock
SMS_API_URL=
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=ELECTRICITY

# ─── WhatsApp Business API ───
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
